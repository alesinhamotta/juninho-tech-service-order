# ============================================================
# JUNINHO.TECH - Variáveis de Ambiente
# ============================================================
# Copie este arquivo e renomeie para .env
# NUNCA envie o arquivo .env para o GitHub!
# ============================================================

# Porta do servidor (padrão: 3001)
PORT=3001

# URL de conexão com o banco de dados Neon Postgres
# Copie a Connection String do painel do Neon (console.neon.tech)
DATABASE_URL=postgresql://neondb_owner:SUA_SENHA@SEU_HOST.neon.tech/neondb?sslmode=require

# Chave secreta para geração de tokens JWT
# Use uma senha longa e aleatória
JWT_SECRET=juninho-tech-2024-coloque-uma-senha-segura-aqui

# Ambiente (development ou production)
NODE_ENV=development

# Origens permitidas para o CORS (separadas por vírgula)
# Em produção, coloque a URL do seu frontend na Vercel
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
