{
  "name": "juninho-tech-service-order",
  "version": "1.0.0",
  "description": "Sistema de Service Order (OS) para JUNINHO.TECH - Gerenciamento de Orçamentos, Vendas e Reparos",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js"
  },
  "keywords": ["service-order", "os", "orçamento", "reparo", "venda", "juninho-tech"],
  "author": "Juninho Tech",
  "license": "MIT",
  "dependencies": {
    "pg": "8.11.3",
    "express": "4.18.2",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "jsonwebtoken": "9.0.2",
    "bcryptjs": "2.4.3",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/pg": "8.11.6",
    "@types/jsonwebtoken": "9.0.6",
    "@types/bcryptjs": "2.4.6",
    "typescript": "5.4.5",
    "concurrently": "8.2.2",
    "tsx": "4.15.7"
  }
}
