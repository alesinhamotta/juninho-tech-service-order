{
  "name": "juninho-tech-service-order",
  "version": "1.0.0",
  "description": "Sistema de Service Order (OS) para JUNINHO.TECH - Gerenciamento de Orçamentos, Vendas e Reparos",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "db:init": "node database/init.js",
    "db:seed": "node database/seed.js"
  },
  "keywords": [
    "service-order",
    "os",
    "orçamento",
    "reparo",
    "venda",
    "juninho-tech"
  ],
  "author": "Juninho Tech",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "pdfkit": "^0.13.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "typescript": "^5.0.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5"
  }
}
